# Required: Secret for signing auth cookies — use a strong random value in production
EWM_SECRET=change-me-in-production

# Port for the Bun WebSocket server (used by both the server and Next.js dev config)
WS_PORT=4444

# WebSocket URL as seen by the browser
# Development: ws://localhost:4444
# Production:  wss://your-domain.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:4444
